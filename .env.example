# ── Layer 1: Search Agents ──────────────────────────────────────
# xAI (Grok) — X/Twitter 实时讨论, 热点追踪
XAI_API_KEY=xai-...
GROK_MODEL=grok-3-mini

# Google (Gemini) — Google 搜索深度整合, 学术内容
GEMINI_API_KEY=AI...
GEMINI_MODEL=gemini-2.5-flash

# ByteDance (Doubao) — 中文互联网全覆盖
DOUBAO_API_KEY=...
DOUBAO_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
DOUBAO_MODEL=doubao-1.5-pro-256k

# Perplexity — 搜索即回答, 自带引用
PERPLEXITY_API_KEY=pplx-...
PERPLEXITY_MODEL=sonar-pro

# ── Better Auth ────────────────────────────────────────────────
BETTER_AUTH_SECRET=your-secret-at-least-32-chars-long-here
BETTER_AUTH_URL=http://localhost:3000

# ── Optional: Web Search API (improves ReAct agent quality) ───
# Serper — Google Search API wrapper, free tier: 2500 queries/month
SERPER_API_KEY=

# ── Layer 2: Integration Models ────────────────────────────────
# Anthropic (Claude) — 整合层首选
ANTHROPIC_API_KEY=sk-ant-...

# DeepSeek — 备选整合层, 性价比高
DEEPSEEK_API_KEY=sk-...
